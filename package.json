{
  "name": "@nk02/shine",
  "version": "0.1.2",
  "description": "Terminal Markdown previewer and docs quality checker for README, changelog, and release-note workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nithish-Yenaganti/shine.git"
  },
  "bugs": {
    "url": "https://github.com/Nithish-Yenaganti/shine/issues"
  },
  "homepage": "https://github.com/Nithish-Yenaganti/shine#readme",
  "bin": {
    "shine": "npm/shine.js"
  },
  "files": [
    "npm/install.js",
    "npm/shine.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "postinstall": "node npm/install.js",
    "publish:npm": "node npm/publish.js",
    "test:npm": "SHINE_BINARY_PATH=bin/shine node npm/shine.js version",
    "test:publish": "node --test npm/publish.test.js"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "markdown",
    "docs",
    "readme",
    "terminal",
    "tui",
    "preview",
    "lint",
    "charm"
  ]
}
